{
  "expo": {
    "name": "TripLog",
    "slug": "triplog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "triplog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "sl.triplog.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "TripLog uses Face ID to quickly and securely unlock the app instead of typing your PIN."
      }
    },
    "android": {
      "package": "sl.triplog.app",
      "adaptiveIcon": {
        "backgroundColor": "#266CA9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "TripLog uses Face ID to quickly and securely unlock the app instead of typing your PIN."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B111C",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
